{
  "capability_tags": [
    "study_workflow",
    "comparative_md",
    "mutation_effect",
    "protein_stability"
  ],
  "category": "experimental_ground_truth",
  "execution_mode": "lite",
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "primary_score": "scientific_answer",
  "references": [
    {
      "note": "FireProtDB curated single-mutation DDG database (scorer-side citation pool).",
      "source": "FireProtDB"
    },
    {
      "note": "S669 / Ssym single-mutation DDG benchmark (scorer-side citation pool).",
      "source": "S669"
    }
  ],
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "evidence_report.json"
  ],
  "schema_version": "1.0",
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "effect_direction_in_allowed_set",
        "check_type": "json_allowed_values",
        "json_file": "evidence_report.json",
        "json_path": "effect.direction",
        "allowed_values": [
          "destabilizing",
          "stabilizing",
          "neutral"
        ],
        "weight": 0.0
      },
      {
        "check_id": "md_trajectories_present",
        "check_type": "json_min_length",
        "json_file": "manifest.json",
        "json_path": "outputs.trajectories",
        "min_length": 2,
        "weight": 0.3
      },
      {
        "check_id": "md_production_time_minimum",
        "check_type": "json_min",
        "json_file": "metrics.json",
        "json_path": "md_analysis.production_time_ns",
        "min_value": 1.0,
        "weight": 0.2
      }
    ],
    "ground_truth_checks": [
      {
        "check_id": "effect_direction_matches_truth",
        "truth_file": "truth/experimental_truth.json",
        "truth_path": "expected_direction",
        "submission_file": "evidence_report.json",
        "submission_path": "effect.direction",
        "weight": 1.0
      }
    ],
    "integrity_checks": [
      {
        "check_id": "evidence_report_real_bytes",
        "check_type": "artifact_min_bytes",
        "path": "evidence_report.json",
        "min_bytes": 400
      },
      {
        "check_id": "evidence_report_not_template",
        "check_type": "template_markers",
        "path": "evidence_report.json",
        "forbid_markers": [
          "Template placeholder",
          "Replace before scoring",
          "Replace with",
          "Generated by create_benchmark_submission_template",
          "fill task-specific"
        ]
      },
      {
        "check_id": "answer_evidence_complete",
        "check_type": "evidence_completeness",
        "required_keys": [
          "effect.direction",
          "limitations",
          "evidence.citations",
          "evidence.md_metrics"
        ]
      },
      {
        "check_id": "real_md_trajectory_artifacts",
        "check_type": "manifest_artifact_floor",
        "manifest_path": "outputs.trajectories",
        "min_count": 2,
        "min_bytes": 1024
      },
      {
        "check_id": "citations_in_allowed_pool",
        "check_type": "citation_pool",
        "allowed_pool_file": "truth/reference_pool.json",
        "citation_field": "evidence.citations"
      },
      {
        "check_id": "workflow_execution_recorded",
        "check_type": "provenance_execution_evidence",
        "min_command_count": 5,
        "required_stages": [
          "source",
          "prep",
          "prod",
          "analysis",
          "report"
        ]
      }
    ],
    "integrity_policy": "reject",
    "llm_judge_rubrics": [
      "confidence_calibration",
      "overclaim_detection"
    ]
  },
  "secondary_scores": [
    "evidence_communication"
  ],
  "task_id": "S01_stability_t4l_l99a",
  "task_intent": "Scientific-answer test: predict the experimental stability direction for T4 lysozyme L99A relative to WT (PDB 2LZM) from MD-derived evidence. Run short comparative MD of WT and the L99A mutant, populate metrics.md_analysis with quantitative differences (core SASA, cavity volume, packing density, C-alpha RMSF in the mutated region, hydrophobic contact count, etc.), populate evidence_report.evidence.md_metrics, and report effect.direction with calibrated confidence and explicit limitations. Literature citations are admissible for confidence calibration only; the direction itself must be defended by the MD numbers.",
  "time_limit_minutes": 120
}
