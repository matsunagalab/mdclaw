{
  "capability_tags": [
    "preparation_workflow",
    "biological_assembly",
    "chain_identity"
  ],
  "category": "system_preparation",
  "environment_type": "artifact_only",
  "evaluation_target": "agent_preparation_fidelity",
  "execution_mode": "lite",
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "prep_battery_priority": 1,
  "primary_score": "preparation",
  "public_source": "PDB 1STP assembly 1; stress variant PDB 2MS2 assembly 1",
  "references": [
    {
      "source": "PDB 1STP",
      "url": "https://www.rcsb.org/structure/1STP"
    },
    {
      "source": "PDB 2MS2",
      "url": "https://www.rcsb.org/structure/2MS2"
    }
  ],
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "evidence_report.json",
    "prepared_structure.pdb"
  ],
  "requires_tools": [
    "structure_preparation"
  ],
  "schema_version": "1.0",
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "assembly_id_recorded",
        "check_type": "json_equals",
        "equals": "1",
        "json_file": "metrics.json",
        "json_path": "preparation.assembly_id",
        "weight": 0.25
      },
      {
        "check_id": "assembly_provenance_recorded",
        "check_type": "json_equals",
        "equals": true,
        "json_file": "metrics.json",
        "json_path": "preparation.assembly_provenance_recorded",
        "weight": 0.35
      },
      {
        "check_id": "chain_identity_map_recorded",
        "check_type": "json_equals",
        "equals": true,
        "json_file": "metrics.json",
        "json_path": "preparation.chain_identity_map_recorded",
        "weight": 0.25
      },
      {
        "check_id": "many_chain_policy_recorded",
        "check_type": "json_equals",
        "equals": true,
        "json_file": "metrics.json",
        "json_path": "preparation.many_chain_policy_recorded",
        "weight": 0.15
      }
    ],
    "ground_truth_checks": [],
    "integrity_checks": [
      {
        "check_id": "evidence_report_real_bytes",
        "check_type": "artifact_min_bytes",
        "min_bytes": 250,
        "path": "evidence_report.json"
      },
      {
        "check_id": "evidence_report_not_template",
        "check_type": "template_markers",
        "forbid_markers": [
          "Generated by create_benchmark_submission_template",
          "fill task-specific",
          "Template placeholder",
          "Replace before scoring",
          "Replace with"
        ],
        "path": "evidence_report.json"
      },
      {
        "check_id": "prepared_structure_real_bytes",
        "check_type": "status_artifact_floor",
        "status_floor": {
          "prepared_structure.pdb": 250
        }
      }
    ],
    "integrity_policy": "warn",
    "llm_judge_rubrics": [
      "provenance_traceability",
      "limitations"
    ]
  },
  "secondary_scores": [
    "evidence_communication"
  ],
  "task_id": "P24_prep_biological_assembly",
  "task_intent": "Assembly/biological unit choice: generate or select the requested biological assembly by assembly_id while preserving source auth/label/operator provenance and stable chain identity.",
  "time_limit_minutes": 60
}
