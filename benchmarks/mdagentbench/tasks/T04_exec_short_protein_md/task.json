{
  "schema_version": "1.0",
  "task_id": "T04_exec_short_protein_md",
  "category": "engine_sanity",
  "primary_score": "execution",
  "secondary_scores": [
    "evidence_communication"
  ],
  "execution_mode": "lite",
  "time_limit_minutes": 60,
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "inputs": {
    "structures": [
      "input/2LZM.pdb"
    ],
    "config_files": [
      "input/prep_request.json",
      "input/md_protocol.json"
    ]
  },
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "evidence_report.json"
  ],
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "execution_completed",
        "check_type": "json_equals",
        "json_file": "metrics.json",
        "json_path": "execution.completed",
        "equals": true,
        "weight": 0.25
      },
      {
        "check_id": "finite_energy",
        "check_type": "json_equals",
        "json_file": "metrics.json",
        "json_path": "execution.finite_energy",
        "equals": true,
        "weight": 0.2
      },
      {
        "check_id": "no_nan",
        "check_type": "json_equals",
        "json_file": "metrics.json",
        "json_path": "execution.no_nan",
        "equals": true,
        "weight": 0.2
      },
      {
        "check_id": "production_length",
        "check_type": "json_min",
        "json_file": "metrics.json",
        "json_path": "execution.simulated_time_ps",
        "min_value": 100.0,
        "weight": 0.1
      },
      {
        "check_id": "trajectory_rescan",
        "check_type": "trajectory_rescan",
        "trajectory_path": "../work/traj_production.dcd",
        "topology_path": "../work/system.topology.pdb",
        "require_min_frames": 50,
        "weight": 0.25
      }
    ],
    "ground_truth_checks": [],
    "llm_judge_rubrics": [
      "limitations"
    ]
  },
  "task_intent": "End-to-end execution test: prepare, equilibrate, and run short protein MD on T4 lysozyme WT (PDB 2LZM). Use ff14SB/TIP3P, equilibrate with positional restraints, perform >= 100 ps NVT production, emit a DCD trajectory with >= 50 frames, and report finite/no-NaN.",
  "references": [
    {
      "note": "T4 lysozyme WT, Matthews lab thermodynamic series.",
      "source": "PDB 2LZM"
    }
  ]
}
