{
  "schema_version": "1.0",
  "task_id": "T04_exec_short_protein_md",
  "category": "engine_sanity",
  "primary_score": "execution",
  "secondary_scores": [
    "evidence_communication"
  ],
  "execution_mode": "lite",
  "capability_tags": [
    "system_preparation",
    "tool_execution",
    "openmm_execution",
    "trajectory_artifact"
  ],
  "environment_type": "local_md_runtime",
  "requires_tools": [
    "structure_preparation",
    "md_engine",
    "trajectory_writer"
  ],
  "evaluation_target": "agent_execution_reliability",
  "time_limit_minutes": 60,
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "evidence_report.json"
  ],
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "execution_completed",
        "check_type": "json_equals",
        "json_file": "metrics.json",
        "json_path": "execution.completed",
        "equals": true,
        "weight": 0.15
      },
      {
        "check_id": "finite_energy",
        "check_type": "json_equals",
        "json_file": "metrics.json",
        "json_path": "execution.finite_energy",
        "equals": true,
        "weight": 0.1
      },
      {
        "check_id": "no_nan",
        "check_type": "json_equals",
        "json_file": "metrics.json",
        "json_path": "execution.no_nan",
        "equals": true,
        "weight": 0.1
      },
      {
        "check_id": "production_length",
        "check_type": "json_min",
        "json_file": "metrics.json",
        "json_path": "execution.simulated_time_ps",
        "min_value": 100.0,
        "weight": 0.1
      },
      {
        "check_id": "trajectory_rescan",
        "check_type": "trajectory_rescan",
        "trajectory_path": "../work/traj_production.dcd",
        "topology_path": "../work/system.topology.pdb",
        "trajectory_manifest_path": "outputs.trajectories.0",
        "topology_manifest_path": "outputs.topology.0",
        "require_min_frames": 50,
        "weight": 0.2
      },
      {
        "check_id": "explicit_water_topology",
        "check_type": "topology_solvent_rescan",
        "topology_path": "../work/system.topology.pdb",
        "topology_manifest_path": "outputs.topology.0",
        "required_solvent_type": "explicit_water",
        "water_residue_names": [
          "HOH",
          "WAT",
          "TIP3",
          "TP3"
        ],
        "min_water_residues": 1000,
        "weight": 0.35
      }
    ],
    "ground_truth_checks": [],
    "llm_judge_rubrics": [
      "limitations"
    ],
    "integrity_checks": [
      {
        "check_id": "evidence_report_real_bytes",
        "check_type": "artifact_min_bytes",
        "path": "evidence_report.json",
        "min_bytes": 200
      },
      {
        "check_id": "evidence_report_not_template",
        "check_type": "template_markers",
        "path": "evidence_report.json",
        "forbid_markers": [
          "Generated by create_benchmark_submission_template",
          "fill task-specific",
          "Template placeholder",
          "Replace before scoring",
          "Replace with"
        ]
      }
    ],
    "integrity_policy": "warn"
  },
  "task_intent": "End-to-end execution test: prepare, equilibrate, and run short protein MD on T4 lysozyme WT (PDB 2LZM) in explicit TIP3P water. Use ff14SB/TIP3P, equilibrate with positional restraints, perform >= 100 ps NVT production, emit a DCD trajectory with >= 50 frames, report finite/no-NaN, and emit a topology PDB containing at least 1000 explicit water residues.",
  "references": [
    {
      "note": "T4 lysozyme WT, Matthews lab thermodynamic series.",
      "source": "PDB 2LZM"
    }
  ]
}
