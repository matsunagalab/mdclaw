{
  "capability_tags": [
    "preparation_workflow",
    "homology_modeling",
    "candidate_selection"
  ],
  "category": "system_preparation",
  "environment_type": "artifact_only",
  "evaluation_target": "agent_preparation_fidelity",
  "execution_mode": "lite",
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "prep_battery_priority": 2,
  "primary_score": "preparation",
  "public_source": "PDB 2LZM plus prompt sequence/alignment",
  "references": [
    {
      "source": "PDB 2LZM",
      "url": "https://www.rcsb.org/structure/2LZM"
    }
  ],
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "evidence_report.json",
    "prepared_structure.pdb"
  ],
  "requires_tools": [
    "structure_preparation"
  ],
  "schema_version": "1.0",
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "model_bundle_recorded",
        "check_type": "json_equals",
        "equals": true,
        "json_file": "metrics.json",
        "json_path": "preparation.model_bundle_recorded",
        "weight": 0.35
      },
      {
        "check_id": "template_reported",
        "check_type": "json_equals",
        "equals": "2LZM",
        "json_file": "metrics.json",
        "json_path": "preparation.template_pdb_id",
        "weight": 0.25
      },
      {
        "check_id": "alignment_recorded",
        "check_type": "json_min_length",
        "json_file": "metrics.json",
        "json_path": "preparation.template_target_alignment",
        "min_length": 1,
        "weight": 0.4
      }
    ],
    "ground_truth_checks": [],
    "integrity_checks": [
      {
        "check_id": "evidence_report_real_bytes",
        "check_type": "artifact_min_bytes",
        "min_bytes": 250,
        "path": "evidence_report.json"
      },
      {
        "check_id": "evidence_report_not_template",
        "check_type": "template_markers",
        "forbid_markers": [
          "Generated by create_benchmark_submission_template",
          "fill task-specific",
          "Template placeholder",
          "Replace before scoring",
          "Replace with"
        ],
        "path": "evidence_report.json"
      },
      {
        "check_id": "prepared_structure_real_bytes",
        "check_type": "status_artifact_floor",
        "status_floor": {
          "prepared_structure.pdb": 250
        }
      }
    ],
    "integrity_policy": "warn",
    "llm_judge_rubrics": [
      "provenance_traceability",
      "limitations"
    ]
  },
  "secondary_scores": [
    "evidence_communication"
  ],
  "task_id": "P20_prep_homology_model_before_prep",
  "task_intent": "Homology modeling before prep: generate a model from the template/alignment and then prepare the selected model, rather than only applying a post-prep mutation.",
  "time_limit_minutes": 60
}
