{
  "capability_tags": [
    "preparation_workflow",
    "site_specific_protonation",
    "hydrogen_rebuild"
  ],
  "category": "system_preparation",
  "environment_type": "artifact_only",
  "evaluation_target": "agent_preparation_fidelity",
  "execution_mode": "lite",
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "prep_battery_priority": 1,
  "primary_score": "preparation",
  "public_source": "PDB 2LZM",
  "references": [
    {
      "source": "PDB 2LZM",
      "url": "https://www.rcsb.org/structure/2LZM"
    }
  ],
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "evidence_report.json",
    "prepared_structure.pdb",
    "minimized_structure.pdb",
    "minimization_report.json"
  ],
  "requires_tools": [
    "structure_preparation"
  ],
  "schema_version": "1.0",
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "requested_state_reported",
        "check_type": "json_equals",
        "equals": "GLH",
        "json_file": "metrics.json",
        "json_path": "preparation.requested_protonation_state",
        "weight": 0.3
      },
      {
        "check_id": "glu11_is_glh_with_he2",
        "check_type": "pdb_residue_state",
        "required_atom_names": [
          "HE2"
        ],
        "required_residue_name": "GLH",
        "residue_chain": "A",
        "residue_number": "11",
        "structure_manifest_path": "outputs.prepared_structure",
        "structure_path": "prepared_structure.pdb",
        "weight": 0.7
      },
      {
        "check_id": "topology_artifact_bundle_present",
        "check_type": "topology_artifact_bundle",
        "min_topology_artifact_count": 1,
        "required_topology_backend": "openmm",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "openmm_system_loads_when_applicable",
        "check_type": "openmm_system_load",
        "required_topology_backend": "openmm",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "openmm_energy_rescan_when_applicable",
        "check_type": "openmm_energy_rescan",
        "required_topology_backend": "openmm",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "minimization_report_confirms_completion",
        "check_type": "minimization_report_check",
        "minimization_report_manifest_path": "outputs.minimization_report",
        "weight": 1.0
      },
      {
        "check_id": "minimized_glu11_is_glh_with_he2",
        "check_type": "pdb_residue_state",
        "required_atom_names": [
          "HE2"
        ],
        "required_residue_name": "GLH",
        "residue_chain": "A",
        "residue_number": "11",
        "structure_manifest_path": "outputs.minimized_structure",
        "structure_path": "minimized_structure.pdb",
        "weight": 0.7
      }
    ],
    "ground_truth_checks": [],
    "integrity_checks": [
      {
        "check_id": "evidence_report_real_bytes",
        "check_type": "artifact_min_bytes",
        "min_bytes": 250,
        "path": "evidence_report.json"
      },
      {
        "check_id": "evidence_report_not_template",
        "check_type": "template_markers",
        "forbid_markers": [
          "Generated by create_benchmark_submission_template",
          "fill task-specific",
          "Template placeholder",
          "Replace before scoring",
          "Replace with"
        ],
        "path": "evidence_report.json"
      },
      {
        "check_id": "prepared_structure_real_bytes",
        "check_type": "status_artifact_floor",
        "status_floor": {
          "minimization_report.json": 100,
          "minimized_structure.pdb": 250,
          "prepared_structure.pdb": 250
        }
      }
    ],
    "integrity_policy": "warn",
    "llm_judge_rubrics": [
      "provenance_traceability",
      "limitations"
    ]
  },
  "secondary_scores": [
    "evidence_communication"
  ],
  "task_id": "P11_prep_site_protonation_t4l_glu11",
  "task_intent": "Specific residue protonation: override the default pH assignment for chain A residue 11 so Glu11 is protonated as GLH.",
  "time_limit_minutes": 60
}
