{
  "capability_tags": [
    "preparation_workflow",
    "ion_concentration",
    "explicit_solvent"
  ],
  "category": "system_preparation",
  "environment_type": "artifact_only",
  "evaluation_target": "agent_preparation_fidelity",
  "execution_mode": "lite",
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "prep_battery_priority": 1,
  "primary_score": "preparation",
  "public_source": "PDB 5AWL",
  "references": [
    {
      "source": "PDB 5AWL",
      "url": "https://www.rcsb.org/structure/5AWL"
    }
  ],
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "evidence_report.json",
    "prepared_structure.pdb"
  ],
  "requires_tools": [
    "structure_preparation"
  ],
  "schema_version": "1.0",
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "salt_species_reported",
        "check_type": "json_equals",
        "equals": "KCl",
        "json_file": "metrics.json",
        "json_path": "preparation.salt_species",
        "weight": 0.25
      },
      {
        "check_id": "salt_concentration_reported",
        "check_type": "json_equals",
        "equals": 0.3,
        "json_file": "metrics.json",
        "json_path": "preparation.salt_concentration_molar",
        "weight": 0.25
      },
      {
        "check_id": "kcl_ions_present",
        "check_type": "structure_component_rescan",
        "min_residue_counts": {
          "CL": 1,
          "K": 1
        },
        "residue_aliases": {
          "CL": [
            "CL-",
            "Cl-"
          ],
          "K": [
            "K+"
          ]
        },
        "structure_manifest_path": "outputs.prepared_structure",
        "structure_path": "prepared_structure.pdb",
        "weight": 0.3
      },
      {
        "check_id": "neutrality_recorded",
        "check_type": "json_equals",
        "equals": true,
        "json_file": "metrics.json",
        "json_path": "preparation.net_charge_neutralized",
        "weight": 0.2
      }
    ],
    "ground_truth_checks": [],
    "integrity_checks": [
      {
        "check_id": "evidence_report_real_bytes",
        "check_type": "artifact_min_bytes",
        "min_bytes": 250,
        "path": "evidence_report.json"
      },
      {
        "check_id": "evidence_report_not_template",
        "check_type": "template_markers",
        "forbid_markers": [
          "Generated by create_benchmark_submission_template",
          "fill task-specific",
          "Template placeholder",
          "Replace before scoring",
          "Replace with"
        ],
        "path": "evidence_report.json"
      },
      {
        "check_id": "prepared_structure_real_bytes",
        "check_type": "status_artifact_floor",
        "status_floor": {
          "prepared_structure.pdb": 250
        }
      }
    ],
    "integrity_policy": "warn",
    "llm_judge_rubrics": [
      "provenance_traceability",
      "limitations"
    ]
  },
  "secondary_scores": [
    "evidence_communication"
  ],
  "task_id": "P25_prep_kcl_ion_concentration",
  "task_intent": "Specified ion concentration: build an explicit-solvent chignolin system that honors 0.30 M KCl while preserving net neutrality.",
  "time_limit_minutes": 60
}
