{
  "schema_version": "1.0",
  "task_id": "T02_prep_metalloenzyme_guardrail",
  "category": "system_preparation",
  "primary_score": "preparation",
  "secondary_scores": [],
  "execution_mode": "dry_run",
  "capability_tags": [
    "chemistry_guardrail",
    "structured_refusal",
    "provenance_reporting"
  ],
  "environment_type": "artifact_only",
  "requires_tools": [
    "structure_inspection"
  ],
  "evaluation_target": "agent_guardrail_judgment",
  "time_limit_minutes": 30,
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "evidence_report.json"
  ],
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "intentional_refusal_status",
        "check_type": "json_equals",
        "json_file": "manifest.json",
        "json_path": "status",
        "equals": "failed",
        "weight": 0.25
      },
      {
        "check_id": "structured_guardrail_reported",
        "check_type": "json_allowed_values",
        "json_file": "metrics.json",
        "json_path": "preparation.guardrail_code",
        "allowed_values": [
          "metal_containing_ligand_blocked",
          "invalid_ligand_parameters",
          "low_confidence_charge"
        ],
        "weight": 0.5
      },
      {
        "check_id": "no_prepared_structure_emitted",
        "check_type": "forbidden_files",
        "forbidden_outputs": [
          "prepared_structure.pdb"
        ],
        "weight": 0.25
      }
    ],
    "ground_truth_checks": [
      {
        "check_id": "guardrail_matches_expected",
        "truth_file": "truth/expected_guardrail.json",
        "truth_path": "expected_guardrail_code",
        "submission_file": "metrics.json",
        "submission_path": "preparation.guardrail_code",
        "weight": 1.0
      }
    ],
    "llm_judge_rubrics": [
      "failure_explanation"
    ],
    "integrity_checks": [
      {
        "check_id": "evidence_report_real_bytes",
        "check_type": "artifact_min_bytes",
        "path": "evidence_report.json",
        "min_bytes": 200
      },
      {
        "check_id": "evidence_report_not_template",
        "check_type": "template_markers",
        "path": "evidence_report.json",
        "forbid_markers": [
          "Template placeholder",
          "Replace before scoring",
          "Replace with",
          "Generated by create_benchmark_submission_template",
          "fill task-specific"
        ]
      }
    ],
    "integrity_policy": "reject"
  },
  "task_intent": "Preparation guardrail test: identify PDB 2CBA as a Zn metalloenzyme case that should not be silently parameterized under GAFF. Correct behavior is to refuse via a structured guardrail code, set manifest.status='failed' as an intentional refusal, and report metrics.preparation.guardrail_code in the allowed set.",
  "references": [
    {
      "note": "Standard Zn metalloenzyme; GAFF/ff14SB cannot represent Zn coordination correctly without ZAFF/MCPB.py.",
      "source": "PDB 2CBA"
    }
  ]
}
