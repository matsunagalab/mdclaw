{
  "schema_version": "1.0",
  "task_id": "T01_engine_smoke",
  "category": "engine_sanity",
  "primary_score": "execution",
  "secondary_scores": [],
  "execution_mode": "lite",
  "capability_tags": [
    "tool_execution",
    "openmm_execution",
    "trajectory_artifact"
  ],
  "environment_type": "local_md_runtime",
  "requires_tools": [
    "md_engine",
    "trajectory_writer"
  ],
  "evaluation_target": "agent_execution_reliability",
  "time_limit_minutes": 30,
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "evidence_report.json"
  ],
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "execution_completed",
        "check_type": "json_equals",
        "json_file": "metrics.json",
        "json_path": "execution.completed",
        "equals": true,
        "weight": 0.15
      },
      {
        "check_id": "finite_energy",
        "check_type": "json_equals",
        "json_file": "metrics.json",
        "json_path": "execution.finite_energy",
        "equals": true,
        "weight": 0.125
      },
      {
        "check_id": "no_nan",
        "check_type": "json_equals",
        "json_file": "metrics.json",
        "json_path": "execution.no_nan",
        "equals": true,
        "weight": 0.125
      },
      {
        "check_id": "trajectory_rescan",
        "check_type": "trajectory_rescan",
        "trajectory_path": "../work/traj.dcd",
        "topology_path": "../work/system.topology.pdb",
        "trajectory_manifest_path": "outputs.trajectories.0",
        "topology_manifest_path": "outputs.topology.0",
        "require_min_frames": 5,
        "weight": 0.25
      },
      {
        "check_id": "explicit_water_topology",
        "check_type": "topology_solvent_rescan",
        "topology_path": "../work/system.topology.pdb",
        "topology_manifest_path": "outputs.topology.0",
        "required_solvent_type": "explicit_water",
        "water_residue_names": [
          "HOH",
          "WAT",
          "TIP3",
          "TP3"
        ],
        "min_water_residues": 100,
        "weight": 0.35
      }
    ],
    "ground_truth_checks": [],
    "llm_judge_rubrics": [],
    "integrity_checks": [
      {
        "check_id": "evidence_report_real_bytes",
        "check_type": "artifact_min_bytes",
        "path": "evidence_report.json",
        "min_bytes": 200
      },
      {
        "check_id": "evidence_report_not_template",
        "check_type": "template_markers",
        "path": "evidence_report.json",
        "forbid_markers": [
          "Generated by create_benchmark_submission_template",
          "fill task-specific",
          "Template placeholder",
          "Replace before scoring",
          "Replace with"
        ]
      }
    ],
    "integrity_policy": "warn"
  },
  "task_intent": "Execution smoke test: run a tiny 10 ps Langevin NVT MD on chignolin (CLN025, PDB 5AWL) in explicit TIP3P water to prove the engine can produce a finite, reloadable trajectory. Report finite energy, no NaN, emit a trajectory file the scorer can re-load, and emit a topology PDB containing explicit water residues.",
  "references": [
    {
      "note": "Honda et al. 2008 \u2014 chignolin CLN025 designed mini-protein.",
      "source": "PDB 5AWL"
    }
  ]
}
