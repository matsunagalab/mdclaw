{
  "capability_tags": [
    "preparation_workflow",
    "membrane",
    "lipids"
  ],
  "category": "system_preparation",
  "environment_type": "artifact_only",
  "evaluation_target": "agent_preparation_fidelity",
  "execution_mode": "lite",
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "prep_battery_priority": 1,
  "primary_score": "preparation",
  "public_source": "PDB 2LOP",
  "references": [
    {
      "source": "PDB 2LOP",
      "url": "https://www.rcsb.org/structure/2LOP"
    }
  ],
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "evidence_report.json",
    "prepared_structure.pdb"
  ],
  "requires_tools": [
    "structure_preparation"
  ],
  "schema_version": "1.0",
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "membrane_flag_recorded",
        "check_type": "json_equals",
        "equals": true,
        "json_file": "metrics.json",
        "json_path": "preparation.membrane",
        "weight": 0.2
      },
      {
        "check_id": "lipid_species_present",
        "check_type": "structure_component_rescan",
        "min_residue_counts": {
          "CHL1": 1,
          "POPC": 2,
          "POPE": 1
        },
        "residue_aliases": {
          "CHL1": [
            "CHL"
          ],
          "POPC": [
            "PC"
          ],
          "POPE": [
            "PE"
          ]
        },
        "structure_manifest_path": "outputs.prepared_structure",
        "structure_path": "prepared_structure.pdb",
        "weight": 0.5
      },
      {
        "check_id": "lipid_ratio_recorded",
        "check_type": "json_equals",
        "equals": "POPC:POPE:CHL1=2:1:1",
        "json_file": "metrics.json",
        "json_path": "preparation.lipid_ratio",
        "weight": 0.3
      }
    ],
    "ground_truth_checks": [],
    "integrity_checks": [
      {
        "check_id": "evidence_report_real_bytes",
        "check_type": "artifact_min_bytes",
        "min_bytes": 250,
        "path": "evidence_report.json"
      },
      {
        "check_id": "evidence_report_not_template",
        "check_type": "template_markers",
        "forbid_markers": [
          "Generated by create_benchmark_submission_template",
          "fill task-specific",
          "Template placeholder",
          "Replace before scoring",
          "Replace with"
        ],
        "path": "evidence_report.json"
      },
      {
        "check_id": "prepared_structure_real_bytes",
        "check_type": "status_artifact_floor",
        "status_floor": {
          "prepared_structure.pdb": 250
        }
      }
    ],
    "integrity_policy": "warn",
    "llm_judge_rubrics": [
      "provenance_traceability",
      "limitations"
    ]
  },
  "secondary_scores": [
    "evidence_communication"
  ],
  "task_id": "P18_prep_membrane_mixed_lipids",
  "task_intent": "Membrane embedding and lipid composition: prepare TMEM14A in a mixed POPC:POPE:CHL1 membrane at a 2:1:1 species ratio.",
  "time_limit_minutes": 60
}
