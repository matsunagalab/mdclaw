{
  "capability_tags": [
    "preparation_workflow",
    "membrane",
    "lipids"
  ],
  "category": "system_preparation",
  "environment_type": "artifact_only",
  "evaluation_target": "agent_preparation_fidelity",
  "execution_mode": "lite",
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "prep_battery_priority": 1,
  "primary_score": "preparation",
  "public_source": "PDB 2LOP",
  "references": [
    {
      "source": "PDB 2LOP",
      "url": "https://www.rcsb.org/structure/2LOP"
    }
  ],
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "evidence_report.json",
    "prepared_structure.pdb",
    "minimized_structure.pdb",
    "minimization_report.json"
  ],
  "requires_tools": [
    "structure_preparation"
  ],
  "schema_version": "1.0",
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "membrane_flag_recorded",
        "check_type": "json_equals",
        "equals": true,
        "json_file": "metrics.json",
        "json_path": "preparation.membrane",
        "weight": 0.2
      },
      {
        "check_id": "selected_model_rank_recorded",
        "check_type": "json_equals",
        "equals": 1,
        "json_file": "metrics.json",
        "json_path": "preparation.selected_model_rank",
        "weight": 0.1
      },
      {
        "check_id": "source_selection_model_1",
        "check_type": "candidate_selection_check",
        "require_selection_reason": false,
        "required_model_rank": 1,
        "source_selection_manifest_path": "outputs.source_selection",
        "source_selection_path": "source_selection.json",
        "weight": 0.2
      },
      {
        "check_id": "lipid_species_present",
        "check_type": "structure_component_rescan",
        "min_residue_counts": {
          "CHL1": 1,
          "POPC": 2,
          "POPE": 1
        },
        "residue_aliases": {
          "CHL1": [
            "CHL",
            "CHOL"
          ],
          "POPC": [
            "PC"
          ],
          "POPE": [
            "PE"
          ]
        },
        "structure_manifest_path": "outputs.prepared_structure",
        "structure_path": "prepared_structure.pdb",
        "weight": 0.5
      },
      {
        "allowed_values": [
          "POPC:POPE:CHL1=2:1:1",
          "PC:PE:CHL=2:1:1"
        ],
        "check_id": "lipid_ratio_recorded",
        "check_type": "json_allowed_values",
        "json_file": "metrics.json",
        "json_path": "preparation.lipid_ratio",
        "weight": 0.3
      },
      {
        "check_id": "topology_artifact_bundle_present",
        "check_type": "topology_artifact_bundle",
        "min_topology_artifact_count": 1,
        "required_topology_backend": "openmm",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "openmm_system_loads_when_applicable",
        "check_type": "openmm_system_load",
        "required_topology_backend": "openmm",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "openmm_energy_rescan_when_applicable",
        "check_type": "openmm_energy_rescan",
        "required_topology_backend": "openmm",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "minimization_report_confirms_completion",
        "check_type": "minimization_report_check",
        "minimization_report_manifest_path": "outputs.minimization_report",
        "weight": 1.0
      },
      {
        "check_id": "minimized_lipid_species_present",
        "check_type": "minimized_structure_component_rescan",
        "min_residue_counts": {
          "CHL1": 1,
          "POPC": 2,
          "POPE": 1
        },
        "minimized_structure_manifest_path": "outputs.minimized_structure",
        "residue_aliases": {
          "CHL1": [
            "CHL",
            "CHOL"
          ],
          "POPC": [
            "PC"
          ],
          "POPE": [
            "PE"
          ]
        },
        "structure_manifest_path": "outputs.prepared_structure",
        "structure_path": "minimized_structure.pdb",
        "weight": 0.5
      }
    ],
    "ground_truth_checks": [],
    "integrity_checks": [
      {
        "check_id": "evidence_report_real_bytes",
        "check_type": "artifact_min_bytes",
        "min_bytes": 250,
        "path": "evidence_report.json"
      },
      {
        "check_id": "evidence_report_not_template",
        "check_type": "template_markers",
        "forbid_markers": [
          "Generated by create_benchmark_submission_template",
          "fill task-specific",
          "Template placeholder",
          "Replace before scoring",
          "Replace with"
        ],
        "path": "evidence_report.json"
      },
      {
        "check_id": "prepared_structure_real_bytes",
        "check_type": "status_artifact_floor",
        "status_floor": {
          "minimization_report.json": 100,
          "minimized_structure.pdb": 250,
          "prepared_structure.pdb": 250
        }
      }
    ],
    "integrity_policy": "warn",
    "llm_judge_rubrics": [
      "provenance_traceability",
      "limitations"
    ]
  },
  "secondary_scores": [
    "evidence_communication"
  ],
  "task_id": "P18_prep_membrane_mixed_lipids",
  "task_intent": "Membrane embedding and lipid composition: prepare model 1 of TMEM14A from the PDB 2LOP NMR ensemble in a mixed POPC:POPE:CHL1 membrane at a 2:1:1 species ratio. Record the selected model rank as 1 and source-selection evidence in `source_selection.json` or structured provenance.",
  "time_limit_minutes": 60
}
