        "submission_file": {
          "default": "evidence_report.json",
          "title": "Submission File",
          "type": "string"
        },
        "submission_path": {
          "title": "Submission Path",
          "type": "string"
        },
        "truth_file": {
          "default": "truth/experimental_truth.json",
          "title": "Truth File",
          "type": "string"
        },
        "truth_path": {
          "title": "Truth Path",
          "type": "string"
        },
        "weight": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Weight",
          "type": "number"
        }
      },
      "required": [
        "check_id",
        "truth_path",
        "submission_path"
      ],
      "title": "GroundTruthCheck",
      "type": "object"
    },
