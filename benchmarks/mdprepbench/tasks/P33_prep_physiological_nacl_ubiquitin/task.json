{
  "capability_tags": [
    "preparation_workflow",
    "ion_concentration",
    "explicit_solvent"
  ],
  "category": "system_preparation",
  "environment_type": "artifact_only",
  "evaluation_target": "agent_preparation_fidelity",
  "execution_mode": "lite",
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "primary_score": "preparation",
  "public_source": "PDB 1UBQ",
  "references": [
    {
      "source": "PDB 1UBQ",
      "url": "https://www.rcsb.org/structure/1UBQ"
    }
  ],
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "prepared_structure.pdb",
    "minimized_structure.pdb",
    "minimization_report.json"
  ],
  "requires_tools": [
    "structure_preparation"
  ],
  "schema_version": "1.0",
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "nacl_ions_present",
        "check_type": "structure_component_rescan",
        "min_residue_counts": {
          "CL": 1,
          "NA": 1
        },
        "residue_aliases": {
          "CL": [
            "CL-",
            "Cl-",
            "CLA"
          ],
          "NA": [
            "NA+",
            "Na+",
            "SOD"
          ]
        },
        "structure_manifest_path": "outputs.topology",
        "structure_path": "topology/topology.pdb",
        "weight": 0.3
      },
      {
        "check_id": "explicit_solvent_rescanned",
        "check_type": "solvent_regime_rescan",
        "min_water_residues": 1,
        "required_solvent_regime": "explicit",
        "topology_manifest_path": "outputs.topology",
        "weight": 0.2
      },
      {
        "allowed_nonstandard_residue_names": [],
        "check_id": "topology_no_unrequested_nonstandard_residues",
        "check_type": "unexpected_residue_rescan",
        "structure_manifest_path": "outputs.topology",
        "structure_path": "topology/topology.pdb",
        "weight": 0.5
      },
      {
        "check_id": "net_charge_neutral_recomputed",
        "check_type": "net_charge_check",
        "require_neutral": true,
        "topology_manifest_path": "outputs.topology",
        "weight": 0.3
      },
      {
        "anion_residue_names": [
          "CL",
          "CL-",
          "Cl-",
          "CLA"
        ],
        "cation_residue_names": [
          "NA",
          "NA+",
          "Na+",
          "SOD"
        ],
        "check_id": "nacl_molarity_recomputed",
        "check_type": "ion_concentration_recompute",
        "min_ion_count": 2,
        "molar_tolerance": 0.05,
        "target_molar": 0.15,
        "topology_manifest_path": "outputs.topology",
        "weight": 0.4
      },
      {
        "check_id": "topology_artifact_bundle_present",
        "check_type": "topology_artifact_bundle",
        "min_topology_artifact_count": 1,
        "required_topology_backend": "openmm",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "openmm_system_loads_when_applicable",
        "check_type": "openmm_system_load",
        "required_topology_backend": "openmm",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "openmm_energy_rescan_when_applicable",
        "check_type": "openmm_energy_rescan",
        "required_topology_backend": "openmm",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "forcefield_applied_to_every_atom",
        "check_type": "forcefield_applied_rescan",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "minimization_report_confirms_completion",
        "check_type": "minimization_report_check",
        "minimization_report_manifest_path": "outputs.minimization_report",
        "weight": 1.0
      },
      {
        "check_id": "structure_geometry_is_clash_free",
        "check_type": "structure_geometry_quality",
        "topology_manifest_path": "outputs.topology",
        "clash_overlap_fraction": 0.6,
        "max_clashes": 0,
        "weight": 1.0
      },
      {
        "allowed_nonstandard_residue_names": [],
        "check_id": "minimized_no_unrequested_nonstandard_residues",
        "check_type": "unexpected_residue_rescan",
        "structure_manifest_path": "outputs.minimized_structure",
        "structure_path": "minimized_structure.pdb",
        "weight": 0.5
      },
      {
        "check_id": "minimized_nacl_ions_present",
        "check_type": "minimized_structure_component_rescan",
        "min_residue_counts": {
          "CL": 1,
          "NA": 1
        },
        "minimized_structure_manifest_path": "outputs.minimized_structure",
        "residue_aliases": {
          "CL": [
            "CL-",
            "Cl-",
            "CLA"
          ],
          "NA": [
            "NA+",
            "Na+",
            "SOD"
          ]
        },
        "structure_manifest_path": "outputs.prepared_structure",
        "structure_path": "minimized_structure.pdb",
        "weight": 0.3
      }
    ],
    "ground_truth_checks": [],
    "integrity_checks": [
      {
        "check_id": "prepared_structure_real_bytes",
        "check_type": "status_artifact_floor",
        "status_floor": {
          "minimization_report.json": 100,
          "minimized_structure.pdb": 250,
          "prepared_structure.pdb": 250
        }
      },
      {
        "check_id": "workflow_execution_recorded",
        "check_type": "provenance_execution_evidence",
        "min_command_count": 1,
        "require_harness_record": true,
        "required_stages": [
          "min"
        ]
      },
      {
        "check_id": "submitted_artifacts_are_hashed",
        "check_type": "submission_artifact_hashes",
        "require_manifest_output_hashes": true
      },
      {
        "check_id": "minimized_structure_matches_submitted_state",
        "check_type": "openmm_minimized_state_consistency",
        "coordinate_tolerance_nm": 0.001
      }
    ],
    "integrity_policy": "reject"
  },
  "task_id": "P33_prep_physiological_nacl_ubiquitin",
  "task_intent": "Physiological salt concentration: build an explicit-solvent ubiquitin system (PDB 1UBQ) at a physiological 0.15 M NaCl concentration while preserving net neutrality, using NaCl (not KCl) as the requested salt.",
  "time_limit_minutes": 60
}
