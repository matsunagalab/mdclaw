{
  "capability_tags": [
    "preparation_workflow",
    "ion_concentration",
    "explicit_solvent"
  ],
  "category": "system_preparation",
  "environment_type": "artifact_only",
  "evaluation_target": "agent_preparation_fidelity",
  "execution_mode": "lite",
  "failure_policy": {
    "blocked_by_missing_input_allowed": false,
    "insufficient_information_allowed": false
  },
  "primary_score": "preparation",
  "public_source": "PDB 5AWL",
  "references": [
    {
      "source": "PDB 5AWL",
      "url": "https://www.rcsb.org/structure/5AWL"
    }
  ],
  "required_outputs": [
    "manifest.json",
    "metrics.json",
    "provenance.json",
    "prepared_structure.pdb",
    "minimized_structure.pdb",
    "minimization_report.json"
  ],
  "requires_tools": [
    "structure_preparation"
  ],
  "schema_version": "1.0",
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "salt_species_reported",
        "check_type": "json_equals",
        "equals": "KCl",
        "json_file": "metrics.json",
        "json_path": "preparation.salt_species",
        "weight": 0.25
      },
      {
        "check_id": "salt_concentration_reported",
        "check_type": "json_equals",
        "equals": 0.3,
        "json_file": "metrics.json",
        "json_path": "preparation.salt_concentration_molar",
        "weight": 0.25
      },
      {
        "check_id": "kcl_ions_present",
        "check_type": "structure_component_rescan",
        "min_residue_counts": {
          "CL": 1,
          "K": 1
        },
        "residue_aliases": {
          "CL": [
            "CL-",
            "Cl-"
          ],
          "K": [
            "K+"
          ]
        },
        "structure_manifest_path": "outputs.prepared_structure",
        "structure_path": "prepared_structure.pdb",
        "weight": 0.3
      },
      {
        "check_id": "neutrality_recorded",
        "check_type": "json_equals",
        "equals": true,
        "json_file": "metrics.json",
        "json_path": "preparation.net_charge_neutralized",
        "weight": 0.1
      },
      {
        "check_id": "net_charge_neutral_recomputed",
        "check_type": "net_charge_check",
        "require_neutral": true,
        "charge_json_file": "metrics.json",
        "charge_json_path": "preparation.net_charge",
        "topology_manifest_path": "outputs.topology",
        "weight": 0.3
      },
      {
        "check_id": "kcl_molarity_recomputed",
        "check_type": "ion_concentration_recompute",
        "cation_residue_names": [
          "K",
          "K+"
        ],
        "anion_residue_names": [
          "CL",
          "CL-",
          "Cl-"
        ],
        "target_molar": 0.3,
        "molar_tolerance": 0.05,
        "min_ion_count": 2,
        "topology_manifest_path": "outputs.topology",
        "weight": 0.4
      },
      {
        "check_id": "topology_artifact_bundle_present",
        "check_type": "topology_artifact_bundle",
        "min_topology_artifact_count": 1,
        "required_topology_backend": "openmm",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "openmm_system_loads_when_applicable",
        "check_type": "openmm_system_load",
        "required_topology_backend": "openmm",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "openmm_energy_rescan_when_applicable",
        "check_type": "openmm_energy_rescan",
        "required_topology_backend": "openmm",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "forcefield_applied_to_every_atom",
        "check_type": "forcefield_applied_rescan",
        "topology_manifest_path": "outputs.topology",
        "weight": 1.0
      },
      {
        "check_id": "minimization_report_confirms_completion",
        "check_type": "minimization_report_check",
        "minimization_report_manifest_path": "outputs.minimization_report",
        "weight": 1.0
      },
      {
        "check_id": "minimized_kcl_ions_present",
        "check_type": "minimized_structure_component_rescan",
        "min_residue_counts": {
          "CL": 1,
          "K": 1
        },
        "minimized_structure_manifest_path": "outputs.minimized_structure",
        "residue_aliases": {
          "CL": [
            "CL-",
            "Cl-"
          ],
          "K": [
            "K+"
          ]
        },
        "structure_manifest_path": "outputs.prepared_structure",
        "structure_path": "minimized_structure.pdb",
        "weight": 0.3
      }
    ],
    "ground_truth_checks": [],
    "integrity_checks": [
      {
        "check_id": "prepared_structure_real_bytes",
        "check_type": "status_artifact_floor",
        "status_floor": {
          "minimization_report.json": 100,
          "minimized_structure.pdb": 250,
          "prepared_structure.pdb": 250
        }
      },
      {
        "check_id": "workflow_execution_recorded",
        "check_type": "provenance_execution_evidence",
        "min_command_count": 4,
        "require_harness_record": true,
        "required_stages": [
          "source",
          "prep",
          "topo",
          "min"
        ]
      }
    ],
    "integrity_policy": "reject",
    "llm_judge_rubrics": [
      "provenance_traceability",
      "limitations"
    ]
  },
  "secondary_scores": [
    "evidence_communication"
  ],
  "task_id": "P25_prep_kcl_ion_concentration",
  "task_intent": "Specified ion concentration: build an explicit-solvent chignolin system that honors 0.30 M KCl while preserving net neutrality.",
  "time_limit_minutes": 60
}
