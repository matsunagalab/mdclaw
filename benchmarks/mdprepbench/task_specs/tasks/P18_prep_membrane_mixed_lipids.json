        "minimized_structure_manifest_path": "outputs.minimized_structure",
        "residue_aliases": {
          "CHL1": [
            "CHL",
            "CHOL",
            "HL1"
          ],
          "POPC": [
            "PC",
            "OPC"
          ],
          "POPE": [
            "PE",
            "OPE"
          ]
