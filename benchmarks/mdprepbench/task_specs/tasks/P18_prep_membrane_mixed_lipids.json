            "CHL",
            "CHOL",
            "HL1"
          ],
          "POPC": [
            "PC",
            "OPC"
          ],
          "POPE": [
            "PE",
            "OPE"
          ]
        },
        "structure_manifest_path": "outputs.topology",
        "structure_path": "topology/topology.pdb",
        "weight": 0.5
      },
      {
        "check_id": "lipid_ratio_rescanned",
        "check_type": "residue_ratio_rescan",
        "required_residue_ratio": {
          "POPC": 2,
          "POPE": 1,
          "CHL1": 1
        },
        "min_residue_atom_count": 20,
        "residue_aliases": {
          "CHL1": [
            "CHL",
            "CHOL",
            "HL1"
          ],
          "POPC": [
            "PC",
            "OPC"
          ],
          "POPE": [
            "PE",
            "OPE"
          ]
        },
        "structure_manifest_path": "outputs.topology",
        "structure_path": "topology/topology.pdb",
        "weight": 0.3
