{
  "task_id": "P18_prep_membrane_mixed_lipids",
  "public_source": "PDB 2LOP",
  "capability_tags_extra": [
    "membrane",
    "lipids"
  ],
  "task_intent": "Membrane embedding and lipid composition: prepare model 1 of TMEM14A from the PDB 2LOP NMR ensemble in a mixed POPC/POPE/CHL1 membrane. Use a packmol-memgen-style nominal composition request of `--lipids POPC:POPE:CHL1 --ratio 2:1:1` or an equivalent membrane-builder setting, but allow the realized integer lipid counts to follow the builder's box-size, area-per-lipid, and rounding behavior. The scorer verifies model selection from the submitted coordinates against a fixed model-1 reference, so no self-reported source-selection evidence is required.",
  "references": [
    {
      "source": "PDB 2LOP",
      "url": "https://www.rcsb.org/structure/2LOP"
    }
  ],
  "scoring": {
    "deterministic_checks": [
      {
        "check_id": "membrane_regime_rescanned",
        "check_type": "solvent_regime_rescan",
        "lipid_residue_names": [
          "POPC",
          "POPE",
          "CHL1",
          "PC",
          "PE",
          "CHL",
          "CHOL",
          "OPC",
          "OPE",
          "HL1"
        ],
        "min_lipid_residues": 4,
        "required_solvent_regime": "membrane",
        "topology_manifest_path": "outputs.topology",
        "weight": 0.2
      },
      {
        "align_selection": "protein and name CA",
        "check_id": "nmr_model_1_coordinate_match",
        "check_type": "rmsd_recompute",
        "max_value": 2.0,
        "reference_pdb": "truth/model_1_reference.pdb",
        "selection": "protein and name CA",
        "tolerance_angstrom": 0.05,
        "weight": 0.2
      },
      {
        "check_id": "lipid_species_present",
        "check_type": "structure_component_rescan",
        "min_residue_atom_count": 20,
        "min_residue_counts": {
          "CHL1": 1,
          "POPC": 2,
          "POPE": 1
        },
        "residue_aliases": {
          "CHL1": [
            "CHL",
            "CHOL",
            "HL1"
          ],
          "POPC": [
            "PC",
            "OPC"
          ],
          "POPE": [
            "PE",
            "OPE"
          ]
        },
        "structure_manifest_path": "outputs.topology",
        "structure_path": "topology/topology.pdb",
        "weight": 0.5
      },
      {
        "$bundle": "topology_minimization"
      },
      {
        "check_id": "minimized_lipid_species_present",
        "check_type": "minimized_structure_component_rescan",
        "min_residue_atom_count": 20,
        "min_residue_counts": {
          "CHL1": 1,
          "POPC": 2,
          "POPE": 1
        },
        "minimized_structure_manifest_path": "outputs.minimized_structure",
        "residue_aliases": {
          "CHL1": [
            "CHL",
            "CHOL",
            "HL1"
          ],
          "POPC": [
            "PC",
            "OPC"
          ],
          "POPE": [
            "PE",
            "OPE"
          ]
        },
        "structure_manifest_path": "outputs.prepared_structure",
        "structure_path": "minimized_structure.pdb",
        "weight": 0.5
      }
    ]
  }
}
