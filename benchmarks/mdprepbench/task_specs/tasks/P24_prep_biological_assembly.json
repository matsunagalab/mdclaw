{
  "task_id": "P24_prep_biological_assembly",
  "public_source": "PDB 1STP assembly 1; stress variant PDB 2MS2 assembly 1",
  "capability_tags_extra": [
    "biological_assembly",
    "chain_identity"
  ],
  "task_intent": "Assembly/biological unit choice: generate or select biological assembly 1 of PDB 1STP. The scorer verifies the submitted coordinates against a fixed assembly-1 reference and checks that the submitted structure contains four protein chains, so assembly identity is not accepted from self-reported JSON alone.",
  "references": [
    {
      "source": "PDB 1STP",
      "url": "https://www.rcsb.org/structure/1STP"
    },
    {
      "source": "PDB 2MS2",
      "url": "https://www.rcsb.org/structure/2MS2"
    }
  ],
  "scoring": {
    "deterministic_checks": [
      {
        "align_selection": "protein and name CA",
        "check_id": "assembly_1_coordinate_match",
        "check_type": "rmsd_recompute",
        "max_value": 2.0,
        "reference_pdb": "truth/assembly_1_reference.pdb",
        "selection": "protein and name CA",
        "tolerance_angstrom": 0.05,
        "weight": 0.75
      },
      {
        "check_id": "assembly_four_chains",
        "check_type": "assembly_identity_check",
        "exact_chain_count": 4,
        "structure_manifest_path": "outputs.prepared_structure",
        "weight": 0.35
      },
      {
        "$bundle": "topology_minimization"
      },
      {
        "check_id": "minimized_assembly_four_chains",
        "check_type": "assembly_identity_check",
        "exact_chain_count": 4,
        "structure_manifest_path": "outputs.minimized_structure",
        "weight": 0.35
      }
    ]
  }
}
